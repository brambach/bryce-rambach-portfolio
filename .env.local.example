# Anthropic — set in Vercel dashboard for preview/production
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — install via Vercel marketplace and it auto-injects these
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile — NOT wired up yet. The server-side verify was
# removed because the client-side widget hasn't been built. Do not set
# these until the Turnstile widget is integrated into the chat input.
# TURNSTILE_SECRET_KEY=
# VITE_TURNSTILE_SITE_KEY=
